{
  "name": "node-red-contrib-signalbox",
  "version": "0.1.1",
  "description": "A zero-config passthrough node that watches traffic going past - like a signalman logging every train - and keeps counts, averages, and top payloads in status and context.",
  "keywords": [
    "node-red",
    "status",
    "monitoring",
    "traffic",
    "stats"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheBartoMan/node-red-contrib-signalbox.git"
  },
  "bugs": {
    "url": "https://github.com/TheBartoMan/node-red-contrib-signalbox/issues"
  },
  "homepage": "https://github.com/TheBartoMan/node-red-contrib-signalbox#readme",
  "engines": {
    "node": ">=18",
    "node-red": ">=3.0.0"
  },
  "node-red": {
    "nodes": {
      "signalbox": "signalbox.js"
    }
  },
  "main": "signalbox.js"
}
